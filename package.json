{
  "name": "claude-cockpit",
  "version": "1.0.0",
  "description": "A visual cockpit for Claude Code sessions — browse history, stream live chat, approve tools, track costs. Personal learning artifact, published as-is. Unofficial third-party tool. Not affiliated with or endorsed by Anthropic.",
  "author": "Bryan Yao",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/narwhalishus/ClaudeCockpit.git"
  },
  "keywords": [
    "claude-code",
    "dashboard",
    "session-viewer",
    "ai-tools",
    "developer-tools",
    "lit",
    "websocket"
  ],
  "type": "module",
  "bin": {
    "claude-cockpit": "./bin/claude-cockpit.js"
  },
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch gateway/server.ts\"",
    "dev:ui": "vite",
    "dev:gateway": "tsx watch gateway/server.ts",
    "start": "node bin/claude-cockpit.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/gateway/integration.test.ts",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm test && npm run build",
    "build": "npm run build:ui && npm run build:gateway",
    "build:ui": "vite build",
    "build:gateway": "tsc -p tsconfig.gateway.json",
    "preview": "vite preview",
    "prepublishOnly": "npm run ci"
  },
  "dependencies": {
    "lit": "^3.3.0",
    "marked": "^17.0.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  }
}
